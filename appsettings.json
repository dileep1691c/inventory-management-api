{
  "Environment": "Dev",
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  "ConnectionStrings": {
    "PostgreSqlConnection": "Host=localhost;Port=5432;Database=InventoryManagement;Username=postgres;Password=XXXXXXXXXXXX"
  },
  "JWTSettings": {
    "Issuer": "http//:InventoryManagement",
    "SecretKey": "",
    "Audience": "http//:InventoryManagement",
    "AccessTokenExpirationTime": 15,
    "RefreshTokenExpirationTime": 1
  },
  "PrimayKeyLocation": "keys\\private.pem",
  "PublicKeyLocation": "keys\\public.pem"
}
